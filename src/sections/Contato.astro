---
// Contato-E: Categorized Support - Design focado em suporte e ajuda rápida
interface Props { title: string; subtitle?: string; desc?: string; content?: string;
}
const { title, subtitle, desc, content } = Astro.props;
const description = subtitle || desc || '';

const faqs = [
  { q: 'Como agendar uma consultoria?', a: 'Basta preencher o formulário selecionando "Consultoria" no assunto.' },
  { q: 'Vocês atendem planos de saúde?', a: 'Trabalhamos com recibos para reembolso de convênios médicos.' },
  { q: 'Qual o tempo médio de resposta?', a: 'Geralmente respondemos em até 12 horas úteis.' }
];
---
<section class="py-24 bg-gray-50 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-16 items-start mb-24">
       
       <!-- Esquerda: Ajuda Rápida -->
       <div>
          <span class="text-primary font-black uppercase tracking-[0.4em] text-[10px] mb-6 block">Suporte Especializado</span>
          <h1 class="text-4xl md:text-6xl font-black text-dark tracking-tighter uppercase leading-none mb-8 italic">{title}</h1>
      {content && <p class="text-gray-500 mt-4 leading-relaxed">{content}</p>}
          <p class="text-xl text-gray-400 font-medium leading-relaxed mb-12">"{description}"</p>
          
          <div class="space-y-6">
             {faqs.map(item => (
               <div class="p-6 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl transition-all group">
                  <h4 class="text-sm font-black text-dark mb-2 tracking-tight group-hover:text-primary transition-colors uppercase">{item.q}</h4>
                  <p class="text-xs text-gray-400 font-medium leading-relaxed italic">{item.a}</p>
               </div>
             ))}
          </div>
       </div>

       <!-- Direita: Categorized Form -->
       <div class="bg-white rounded-[3rem] p-10 md:p-16 shadow-2xl border border-gray-100 relative group">
          <h2 class="text-3xl font-black mb-10 tracking-tight text-dark uppercase italic">Inicie seu Contato</h2>
          <form class="grid gap-6">
             <div class="grid gap-6">
                <input type="text" placeholder="Seu Nome" class="w-full bg-gray-50 border border-gray-100 rounded-2xl p-4 text-dark focus:border-primary focus:outline-none transition-all" />
                <select class="w-full bg-gray-50 border border-gray-100 rounded-2xl p-4 text-dark focus:border-primary focus:outline-none transition-all">
                   <option>Assunto: Consultoria</option>
                   <option>Assunto: Pesquisa Acadêmica</option>
                   <option>Assunto: Apoio Familiar</option>
                   <option>Assunto: Outros</option>
                </select>
             </div>
             <textarea placeholder="Sua Mensagem..." rows="6" class="w-full bg-gray-50 border border-gray-100 rounded-2xl p-4 text-dark focus:border-primary focus:outline-none transition-all resize-none"></textarea>
             <button class="w-full bg-dark text-white py-5 rounded-2xl font-black uppercase tracking-[0.4em] text-[10px] hover:bg-primary transition-all shadow-xl shadow-dark/10">
                Enviar Requisição
             </button>
          </form>
       </div>
    </div>
  </div>
</section>