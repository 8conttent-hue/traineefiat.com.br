---
// Posts-C: Cards horizontais largos
import { getAllPosts } from '../lib/posts';
interface Props { title: string; limit: number; btnText: string; btnLink: string; }
const { title, limit, btnText, btnLink } = Astro.props;

const posts = (await getAllPosts()).slice(0, limit);

const [featured, ...rest] = posts;
---
<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Header -->
    <div class="flex items-end justify-between mb-12">
      <div>
        <span class="text-xs font-bold uppercase tracking-widest text-primary mb-2 block">Blog</span>
        <h2 class="text-3xl md:text-4xl font-black text-dark">{title}</h2>
      </div>
      <a href={btnLink} class="hidden md:flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all">
        {btnText} →
      </a>
    </div>

    <div class="grid md:grid-cols-5 gap-6">
      <!-- Post destaque (coluna grande) -->
      {featured && (
        <article class="md:col-span-3 group bg-white rounded-3xl overflow-hidden border border-gray-100 hover:shadow-xl transition-all">
          <div class="aspect-video bg-gradient-to-br from-primary/10 to-accent/5 overflow-hidden">
            {featured.heroImage && (
              <img
                src={featured.heroImage}
                alt={featured.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="eager"
              />
            )}
          </div>
          <div class="p-7">
            <div class="text-xs font-bold text-primary uppercase tracking-widest mb-3">
              {featured.category || 'Destaque'}
            </div>
            <h3 class="text-xl font-black text-dark leading-snug mb-3 group-hover:text-primary transition-colors">
              <a href={`/${featured.slug}`}>{featured.title}</a>
            </h3>
            <p class="text-gray-500 leading-relaxed text-sm line-clamp-3">{featured.description}</p>
          </div>
        </article>
      )}

      <!-- Posts secundários (coluna menor) -->
      <div class="md:col-span-2 space-y-4">
        {rest.map(post => (
          <article class="group flex gap-4 bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-md transition-all p-4">
            <div class="w-20 h-20 shrink-0 rounded-xl bg-gradient-to-br from-primary/10 to-accent/5 overflow-hidden">
              {post.heroImage && (
                <img
                  src={post.heroImage}
                  alt={post.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              )}
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-[10px] font-bold text-primary uppercase tracking-widest mb-1">
                {post.category || 'Blog'}
              </div>
              <h3 class="font-bold text-dark text-sm leading-snug group-hover:text-primary transition-colors line-clamp-2">
                <a href={`/${post.slug}`}>{post.title}</a>
              </h3>
              <div class="text-xs text-gray-400 mt-2">
                {new Date(post.pubDate).toLocaleDateString('pt-BR', { day: 'numeric', month: 'short' })}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- CTA mobile -->
    <div class="text-center mt-8 md:hidden">
      <a href={btnLink} class="inline-flex items-center gap-2 text-sm font-bold text-primary">
        {btnText} →
      </a>
    </div>
  </div>
</section>